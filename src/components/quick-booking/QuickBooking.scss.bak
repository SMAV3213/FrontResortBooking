@import '../../styles/variables.scss';

.quick-booking {
  position: relative;
  padding: 60px 20px;
  background: linear-gradient(135deg, #0369a1 0%, #0ea5e9 100%);
  color: white;
  overflow: hidden;

  .quick-booking-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 600"><defs><pattern id="water" x="0" y="0" width="200" height="200" patternUnits="userSpaceOnUse"><path d="M0,100 Q50,80 100,100 T200,100" stroke="%23ffffff" stroke-width="1" fill="none" opacity="0.1"/></pattern></defs><rect width="1200" height="600" fill="%23003d66"/><rect width="1200" height="600" fill="url(%23water)"/></svg>');
    opacity: 0.2;
    pointer-events: none;
  }

  .quick-booking-content {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .quick-booking-inner {
    text-align: center;
    margin-bottom: 40px;

    h2 {
      font-size: 36px;
      color: white;
      margin-bottom: 8px;
    }

    p {
      font-size: 18px;
      color: rgba(white, 0.9);
      margin-bottom: 0;
    }
  }

  .quick-booking-form {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 16px;
    max-width: 700px;
    margin: 0 auto;
    align-items: flex-end;

    .form-group {
      text-align: left;

      label {
        display: block;
        margin-bottom: 6px;
        font-weight: 600;
        font-size: 13px;
        color: rgba(white, 0.95);
      }

      .form-input {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        background: white;
        color: #000;

        &:focus {
          outline: none;
          box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
        }
      }
    }

    .search-btn {
      background: white;
      color: #0369a1;
      border: none;
      border-radius: 8px;
      padding: 12px 32px;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
      height: 44px;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
      }

      &:active {
        transform: translateY(0);
      }
    }
  }
}

@media (max-width: 768px) {
  .quick-booking {
    padding: 40px 20px;

    .quick-booking-inner {
      h2 {
        font-size: 24px;
      }

      p {
        font-size: 14px;
      }
    }

    .quick-booking-form {
      grid-template-columns: 1fr;
    }
  }
}
