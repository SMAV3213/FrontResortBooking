@import '../../styles/variables.scss';

.search-results {
  padding: 40px 0;

  .loading,
  .no-results {
    text-align: center;
    padding: 60px 20px;

    p {
      font-size: 18px;
      color: $text-secondary;
    }

    .text-muted {
      font-size: 14px;
      color: $text-light;
    }
  }

  .results-header {
    margin-bottom: 32px;

    h2 {
      font-size: 28px;
      margin-bottom: 8px;
      color: $primary-color;
    }

    .results-count {
      font-size: 14px;
      color: $text-light;
    }
  }

  .rooms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .room-card {
    @include card;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: $transition;

    &:hover {
      transform: translateY(-4px);
      box-shadow: $shadow-lg;
    }

    .room-images {
      width: 100%;
      height: 240px;
      overflow: hidden;
      background-color: $bg-secondary;
      margin-bottom: 16px;

      .room-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: $transition;

        &:hover {
          transform: scale(1.05);
        }
      }

      .room-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: $bg-tertiary;
        color: $text-light;
        font-weight: 500;
      }
    }

    .room-details {
      flex: 1;
      display: flex;
      flex-direction: column;

      h3 {
        margin-bottom: 8px;
        color: $text-primary;
        font-size: 20px;
      }

      .room-description {
        color: $text-secondary;
        font-size: 14px;
        margin-bottom: 12px;
        flex: 1;
        overflow: hidden;
        display: -webkit-box;
        line-clamp: 2;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
      }

      .room-info {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
        flex-wrap: wrap;

        .capacity {
          font-size: 13px;
          color: $text-secondary;
          display: flex;
          align-items: center;
          gap: 4px;
        }
      }

      .room-pricing {
        border-top: 1px solid $border-color;
        padding-top: 12px;
        margin-bottom: 16px;

        .price-per-night {
          font-size: 13px;
          color: $text-secondary;
          margin-bottom: 4px;
        }

        .total-price {
          font-size: 18px;
          font-weight: 700;
          color: $primary-color;

          strong {
            color: $primary-color;
          }
        }
      }

      .book-button {
        @include button-base;
        background: linear-gradient(135deg, #06b6d4 0%, #0369a1 100%);
        color: white;
        font-weight: 700;
        width: 100%;
        height: 40px;

        &:hover:not(:disabled) {
          box-shadow: 0 8px 16px rgba(#06b6d4, 0.3);
        }
      }
    }
  }
}

@media (max-width: 768px) {
  .search-results {
    .rooms-grid {
      grid-template-columns: 1fr;
    }
  }
}
