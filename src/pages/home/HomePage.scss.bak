@import '../../styles/variables.scss';

.home-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

// Hero Section
.hero {
  background: linear-gradient(135deg, #0369a1 0%, #0ea5e9 100%);
  color: white;
  padding: 100px 20px;
  text-align: center;
  margin-bottom: 0;

  .hero-content {
    max-width: 800px;
    margin: 0 auto;

    h1 {
      font-size: 48px;
      margin-bottom: 16px;
      color: white;
    }

    p {
      font-size: 20px;
      margin-bottom: 32px;
      color: rgba(white, 0.9);
    }

    .hero-button {
      @include button-base;
      background: white;
      color: #0369a1;
      font-weight: 700;
      font-size: 16px;
      height: 48px;
      padding: 0 32px;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
      }
    }
  }
}

// Features Section
.features {
  padding: 60px 20px;
  background: $bg-secondary;
  margin-bottom: 0;

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    text-align: center;
    margin-bottom: 48px;
    font-size: 36px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
  }

  .feature-card {
    @include card;
    text-align: center;
    padding: 32px;

    .feature-icon {
      font-size: 48px;
      margin-bottom: 16px;
      display: inline-block;
    }

    h3 {
      margin-bottom: 12px;
      font-size: 20px;
    }

    p {
      color: $text-secondary;
      font-size: 14px;
    }

    &:hover {
      transform: translateY(-4px);
      box-shadow: $shadow-lg;
    }
  }
}

// CTA Section
.cta {
  background: linear-gradient(135deg, #0ea5e9 0%, #0369a1 100%);
  color: white;
  padding: 80px 20px;
  text-align: center;
  margin-bottom: 60px;

  .cta-content {
    max-width: 700px;
    margin: 0 auto;

    h2 {
      color: white;
      font-size: 36px;
      margin-bottom: 16px;
    }

    p {
      color: rgba(white, 0.9);
      font-size: 18px;
      margin-bottom: 32px;
    }

    .cta-button {
      @include button-base;
      background: white;
      color: #0369a1;
      font-weight: 700;
      font-size: 16px;
      height: 48px;
      padding: 0 32px;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
      }
    }
  }
}

// Footer
.footer {
  background: $bg-primary;
  border-top: 1px solid $border-color;
  padding: 40px 20px;
  margin-top: auto;

  .container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  p {
    color: $text-secondary;
    font-size: 14px;
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 24px;

    a {
      color: #0369a1;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: $transition;

      &:hover {
        color: #0ea5e9;
        text-decoration: underline;
      }
    }
  }
}

@media (max-width: 768px) {
  .hero {
    padding: 60px 20px;

    .hero-content {
      h1 {
        font-size: 36px;
      }

      p {
        font-size: 18px;
      }
    }
  }

  .features {
    padding: 40px 20px;

    h2 {
      font-size: 28px;
      margin-bottom: 32px;
    }

    .features-grid {
      gap: 20px;
    }

    .feature-card {
      padding: 24px;
    }
  }

  .cta {
    padding: 60px 20px;

    .cta-content {
      h2 {
        font-size: 28px;
      }

      p {
        font-size: 16px;
      }
    }
  }

  .footer {
    .container {
      flex-direction: column;
      text-align: center;
    }

    .footer-links {
      justify-content: center;
    }
  }
}
